FROM python:3.11-slim

WORKDIR /app

# Node + the claude CLI: ClaudeCodeLLMClient (backend/llm/) spawns `claude`
# via claude-agent-sdk for Graphiti entity extraction.
RUN apt-get update \
    && apt-get install -y --no-install-recommends nodejs npm \
    && npm install -g @anthropic-ai/claude-code \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    graphiti-core>=0.28.0 \
    neo4j>=5.26.0 \
    psycopg2-binary>=2.9.0 \
    requests>=2.31.0 \
    minio>=7.2.0 \
    duckdb>=0.10.0 \
    numpy>=1.26.0 \
    pandas>=2.2.0 \
    pyarrow>=15.0.0 \
    claude-agent-sdk==0.1.71 \
    httpx

COPY backend/crucix_bridge.py .
COPY backend/llm/ ./llm/
COPY backend/scripts/panel_build.py scripts/
COPY backend/scripts/finnhub_earnings_ingest.py scripts/
COPY backend/scripts/sec_cik_ticker_ingest.py scripts/
COPY backend/scripts/sec_8k_ingest.py scripts/

EXPOSE 8090

ENV PYTHONUNBUFFERED=1
CMD ["python", "crucix_bridge.py"]
