FROM python:3.11-slim

WORKDIR /app

RUN pip install --no-cache-dir \
    graphiti-core>=0.28.0 \
    neo4j>=5.26.0 \
    psycopg2-binary>=2.9.0 \
    requests>=2.31.0

COPY backend/crucix_bridge.py .
COPY backend/scripts/benzinga_analyst_ingest.py scripts/
COPY backend/scripts/polymarket_ingest.py scripts/

EXPOSE 8090

ENV PYTHONUNBUFFERED=1
CMD ["python", "crucix_bridge.py"]
